---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description?: string;
  published: Date;
  updated?: Date;
  tags: string[];
}

const { title, description, published, updated, tags } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, "https://kowori.net").toString();
const shareText = `${title} | kowori.net`;
const blueskyUrl = `https://bsky.app/intent/compose?text=${encodeURIComponent(`${shareText}\n${canonicalUrl}`)}`;
const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(canonicalUrl)}`;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(date);
---

<Layout title={title} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <p class="post-kicker">BLOG ENTRY</p>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={published.toISOString()}>PUBLISHED: {formatDate(published)}</time>
        {updated && <time datetime={updated.toISOString()}>UPDATED: {formatDate(updated)}</time>}
      </div>
      {tags.length > 0 && (
        <ul class="tag-list" aria-label="タグ">
          {tags.map(tag => <li>#{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="post-body">
      <slot />
    </div>

    <footer class="post-footer">
      <p class="share-label">REACTION / SHARE</p>
      <div class="share-links">
        <a href={blueskyUrl} target="_blank" rel="noopener">[ BLUESKY ]</a>
        <a href={xUrl} target="_blank" rel="noopener">[ X ]</a>
      </div>
      <a class="back-link" href="/blog">← BLOG INDEX</a>
    </footer>
  </article>
</Layout>

<style>
  .blog-post {
    max-width: 760px;
  }

  .post-header {
    border-bottom: 2px dashed var(--color-border);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
  }

  .post-kicker,
  .share-label {
    color: var(--color-accent);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-2);
  }

  .post-meta {
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    gap: var(--space-3);
    letter-spacing: 0.05em;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-3) 0 0;
  }

  .tag-list li {
    color: var(--color-tag);
    font-size: var(--font-sx);
    margin: 0;
  }

  .post-body :global(img) {
    border: 2px solid var(--color-border);
    display: block;
    height: auto;
    margin: var(--space-4) auto;
    max-width: 100%;
  }

  .post-body :global(h2) {
    margin-top: var(--space-5);
  }

  .post-body :global(h3) {
    color: var(--color-accent);
    font-size: var(--font-sm);
    margin-top: var(--space-4);
    text-transform: none;
  }

  .post-body :global(p) {
    max-width: none;
  }

  .post-footer {
    border-top: 2px dashed var(--color-border);
    margin-top: var(--space-6);
    padding-top: var(--space-4);
  }

  .share-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .share-links a,
  .back-link {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
  }
</style>
