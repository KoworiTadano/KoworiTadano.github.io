---
import { getCollection } from "astro:content";

// 殿堂入り（rank: 0）を除いてスコア降順、同率は日付降順（新しい順）
const all = (await getCollection("reviews"))
  .filter(r => r.data.rank !== 0)
  .sort((a, b) => b.data.score - a.data.score || b.data.date.valueOf() - a.data.date.valueOf());

const picks = all.slice(0, 5);

const buildDate = new Date().toISOString().slice(0, 10);

const medals = ["🥇", "🥈", "🥉"];

const scoreColor = (score: number) => {
  if (score >= 9) return "#00ffcc";
  if (score >= 7) return "#ffe566";
  if (score >= 5) return "#ff9500";
  return "#ff2d78";
};
---

<div class="top-reviews">
  <div class="section-title">
    <span>// TOP REVIEWS</span>
    <span class="build-date">{buildDate}</span>
  </div>
  <ol class="review-list">
    {picks.map((r, i) => (
      <li class="review-item">
        <a href={`/reviews#${r.slug}`} class="review-link">
          <span class="title">
            {i < 3 && <span class="medal">{medals[i]}</span>}
            {r.data.title}
          </span>
          <span class="score" style={`color: ${scoreColor(r.data.score)}`}>
            {r.data.score}<span class="score-max">/10</span>
          </span>
        </a>
      </li>
    ))}
  </ol>
</div>

<style>
  .top-reviews {
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-4);
  }

  .section-title {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-2);
  }

  .build-date {
    opacity: 0.6;
  }

  .review-list {
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .review-item {
    border-top: 1px solid var(--color-border);
  }

  .review-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) 0;
    text-decoration: none;
    gap: var(--space-3);
  }

  .review-link:hover .title {
    color: var(--color-primary);
  }

  .title {
    font-size: var(--font-sm);
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .medal {
    font-size: 0.9rem;
    line-height: 1;
  }

  .score {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .score-max {
    font-size: 0.4rem;
    color: var(--color-muted);
    margin-left: 1px;
  }
</style>
