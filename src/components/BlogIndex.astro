---
import type { CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
const pageHref = (page: number) => page === 1 ? "/blog/" : `/blog/page/${page}/`;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(date);
---

<Layout title="blog" description="kowori.netのブログ。ゲームやPCについての記録。">
  <header class="blog-header">
    <h1>BLOG <span>// GAME LOG &amp; MISC</span></h1>
    <p>&gt; static entries loaded_</p>
  </header>

  <ol class="post-list">
    {posts.map(post => (
      <li class="terminal-panel">
        <a href={`/blog/${post.slug}/`}>
          <time datetime={post.data.published.toISOString()}>{formatDate(post.data.published)}</time>
          <h2>{post.data.title}</h2>
          {post.data.description?.trim() && <p>{post.data.description}</p>}
          {post.data.tags.length > 0 && (
            <span class="tags">{post.data.tags.map(tag => `#${tag}`).join(" ")}</span>
          )}
        </a>
      </li>
    ))}
  </ol>

  {totalPages > 1 && (
    <nav class="pagination" aria-label="ブログ記事ページ">
      {currentPage > 1 ? (
        <a href={pageHref(currentPage - 1)}>← PREV</a>
      ) : (
        <span aria-hidden="true">← PREV</span>
      )}

      <span>PAGE {currentPage} / {totalPages}</span>

      {currentPage < totalPages ? (
        <a href={pageHref(currentPage + 1)}>NEXT →</a>
      ) : (
        <span aria-hidden="true">NEXT →</span>
      )}
    </nav>
  )}
</Layout>

<style>
  .blog-header {
    margin-bottom: var(--space-5);
  }

  .blog-header h1 span {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--font-sx);
    text-shadow: none;
  }

  .blog-header p {
    color: var(--color-muted);
    font-size: var(--font-sm);
  }

  .post-list {
    display: grid;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
  }

  .post-list li {
    margin: 0;
  }

  .post-list a {
    display: block;
    padding: var(--space-4);
    text-decoration: none;
  }

  .post-list a:hover {
    box-shadow: var(--pixel-shadow);
    text-decoration: none;
  }

  .post-list time {
    color: var(--color-muted);
    font-family: var(--font-pixel);
    font-size: 0.45rem;
  }

  .post-list h2 {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: var(--font-lg);
    margin: var(--space-2) 0;
  }

  .post-list p {
    color: var(--color-text);
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .tags {
    color: var(--color-tag);
    font-size: var(--font-sx);
  }

  .pagination {
    align-items: center;
    border-top: 2px dashed var(--color-border);
    display: grid;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    grid-template-columns: 1fr auto 1fr;
    margin-top: var(--space-5);
    padding-top: var(--space-4);
  }

  .pagination > :last-child {
    text-align: right;
  }

  .pagination span {
    color: var(--color-muted);
  }

  @media (max-width: 560px) {
    .pagination {
      font-size: 0.42rem;
    }
  }
</style>
