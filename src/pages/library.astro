---
import Layout from "../layouts/Layout.astro";
import { allGames, gameStatus, library, statusLabels } from "../data/library";

const scoreColor = (score: number) => {
  if (score >= 9) return "#00ffcc";
  if (score >= 7) return "#ffe566";
  if (score >= 5) return "#ff9500";
  return "#ff2d78";
};

const total = allGames.length;
const backlogTotal = allGames.filter(game => gameStatus(game) === "backlog").length;
---

<Layout title="library" description="所持ゲーム一覧と点数とステータス">
  <h1>LIBRARY <span class="collection-type">// Collection Status &amp; Scores</span></h1>
  <div class="db-header terminal-panel">
    <div>
      <span class="db-label">DATABASE</span>
      <span class="db-value">KOWORI_GAME_ARCHIVE</span>
    </div>
    <div>
      <span class="db-label">RECORDS</span>
      <span class="db-value">{total}</span>
    </div>
    <div>
      <span class="db-label">VAULT</span>
      <span class="db-value">{backlogTotal}/{total}</span>
    </div>
    <div class="sort-controls">
      <button class="sort-btn" data-sort="asc" data-active="true">ASC</button>
      <button class="sort-btn" data-sort="desc">DESC</button>
    </div>
  </div>

  <dl class="status-guide terminal-panel">
    <div>
      <dt class="status-text active">ACTIVE</dt>
      <dd>&gt; playing now</dd>
    </div>
    <div>
      <dt class="status-text backlog">VAULT</dt>
      <dd>&gt; backlog / parked</dd>
    </div>
    <div>
      <dt class="status-text cleared">CLEAR</dt>
      <dd>&gt; finished enough</dd>
    </div>
  </dl>

  <div class="platform-grid">
    {library.filter(g => g.games.length > 0).map(group => (
      <div class="platform-box terminal-panel">
        <div class="terminal-titlebar">
          <span>FILE: {group.platform}</span>
          <span class="terminal-meta">{group.games.length} RECORDS</span>
        </div>
        <ul>
          {group.games.map(g => {
            const status = gameStatus(g);
            return (
              <li>
                <span class="bullet">&gt;</span>
                <span class="game-title">{g.title}</span>
                {g.score !== undefined && (
                  <span
                    class:list={["score-badge", { "hall-of-fame": g.rank === 0 }]}
                    style={`color: ${scoreColor(g.score)}; border-color: ${scoreColor(g.score)}66;`}
                  >
                    {g.rank === 0 && <span class="score-star">★</span>}
                    {g.score}<span class="score-max">/10</span>
                  </span>
                )}
                <span class:list={["status-badge", status]}>
                  {statusLabels[status]}
                </span>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>

  {library.some(g => g.games.length === 0) && (
    <div class="tbd-grid">
      {library.filter(g => g.games.length === 0).map(group => (
        <div class="platform-box empty terminal-panel">
          <div class="terminal-titlebar">
            <span>FILE: {group.platform}</span>
            <span class="terminal-meta">NO DATA</span>
          </div>
          <div class="tbd">// TBD</div>
        </div>
      ))}
    </div>
  )}

  <div class="lostfound-section">
    <h2 class="lostfound-title">🗑️ LOST &amp; FOUND</h2>
    <div class="platform-box lostfound-box terminal-panel">
      <ul>
        <li><span class="bullet">&gt;</span>エグゾイドZ</li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  .collection-type {
    font-size: var(--font-sm);
    color: var(--color-accent);
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.1em;
  }

  .platform-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .db-header {
    display: grid;
    grid-template-columns: 1.5fr 0.7fr 0.8fr auto;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .db-header > div {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .db-label {
    font-family: var(--font-pixel);
    font-size: 0.38rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }

  .db-value {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    text-shadow: 0 0 6px var(--color-primary);
  }

  .status-guide {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
  }

  .status-guide div {
    padding: var(--space-2) var(--space-3);
    border-left: 1px solid var(--color-border);
  }

  .status-guide div:first-child {
    border-left: none;
  }

  .status-guide dt {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.08em;
  }

  .status-guide dd {
    margin: 4px 0 0;
    color: var(--color-muted);
    font-size: var(--font-sx);
  }

  @media (max-width: 600px) {
    .db-header {
      grid-template-columns: 1fr;
    }

    .status-guide {
      grid-template-columns: 1fr;
    }

    .status-guide div {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }

    .status-guide div:first-child {
      border-top: none;
    }
  }

  .platform-box {
    padding: 0;
  }

  .tbd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  @media (max-width: 600px) {
    .tbd-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .lostfound-section {
    margin-top: var(--space-6);
    border-top: 2px dashed var(--color-border);
    padding-top: var(--space-4);
  }

  .lostfound-title {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }

  .lostfound-box {
    border-style: dashed;
    opacity: 0.6;
  }

  .platform-box.empty {
    border-style: dashed;
    opacity: 0.4;
  }

  .tbd {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    padding: var(--space-3);
  }

  .platform-box ul {
    list-style: none;
    margin: 0;
    padding: var(--space-3);
    font-size: var(--font-sm);
    columns: 3;
    column-gap: var(--space-5);
  }

  @media (max-width: 600px) {
    .platform-box ul { columns: 2; }
  }

  .platform-box li {
    margin-bottom: var(--space-1);
    color: var(--color-text);
    break-inside: avoid;
  }

  .bullet {
    color: var(--color-primary);
    margin-right: 4px;
    font-family: var(--font-pixel);
    font-size: 0.48rem;
  }

  .game-title {
    margin-right: 6px;
  }

  .score-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
    border: 1px solid;
    padding: 1px 4px;
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    line-height: 1.4;
    white-space: nowrap;
    text-shadow: 0 0 6px currentColor;
    vertical-align: 1px;
  }

  .score-badge.hall-of-fame {
    border-color: #ffd70099 !important;
  }

  .score-star {
    color: #ffd700;
    margin-right: 2px;
  }

  .score-max {
    color: var(--color-muted);
    font-size: 0.34rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
    padding: 1px 5px;
    font-family: var(--font-pixel);
    font-size: 0.38rem;
    line-height: 1.4;
    white-space: nowrap;
    vertical-align: 1px;
  }

  .status-badge.active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }

  .status-text.active {
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }

  .status-badge.backlog {
    border-color: var(--color-muted);
    color: var(--color-muted);
  }

  .status-text.backlog {
    color: var(--color-muted);
  }

  .status-badge.cleared {
    border-color: #1f7f4c;
    color: #1f7f4c;
  }

  .status-text.cleared {
    color: #1f7f4c;
  }

  .sort-controls {
    display: flex;
    gap: var(--space-2);
    justify-content: flex-end;
  }

  .sort-btn {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.08em;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    padding: 2px 8px;
    cursor: pointer;
  }

  .sort-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .sort-btn[data-active="true"] {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }
</style>

<script>
  type SortOrder = "default" | "asc" | "desc";

  // 各ulのli要素を元の順序で記憶
  const lists = document.querySelectorAll<HTMLUListElement>(".platform-box ul");
  const originals = new Map<HTMLUListElement, HTMLLIElement[]>();
  lists.forEach(ul => {
    originals.set(ul, [...ul.querySelectorAll<HTMLLIElement>("li")]);
  });

  function applySort(order: SortOrder) {
    lists.forEach(ul => {
      const items = order === "default"
        ? [...(originals.get(ul) ?? [])]
        : [...ul.querySelectorAll<HTMLLIElement>("li")].sort((a, b) => {
            const ta = a.textContent?.trim() ?? "";
            const tb = b.textContent?.trim() ?? "";
            return order === "asc"
              ? ta.localeCompare(tb, "ja")
              : tb.localeCompare(ta, "ja");
          });
      items.forEach(li => ul.appendChild(li));
    });
  }

  applySort("asc");

  document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".sort-btn").forEach(b => b.removeAttribute("data-active"));
      btn.dataset.active = "true";
      applySort(btn.dataset.sort as SortOrder);
    });
  });
</script>
