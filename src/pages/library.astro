---
import Layout from "../layouts/Layout.astro";
import { allGames, gameStatus, library, statusLabels } from "../data/library";

const scoreColor = (score: number) => {
  if (score >= 9) return "#00ffcc";
  if (score >= 7) return "#ffe566";
  if (score >= 5) return "#ff9500";
  return "#ff2d78";
};

const total = allGames.length;
const backlogTotal = allGames.filter(game => gameStatus(game) === "backlog").length;
---

<Layout title="library" description="所持ゲーム一覧と点数とステータス">
  <h1>LIBRARY <span class="collection-type">// Collection Status &amp; Scores</span></h1>
  <div class="db-header terminal-panel">
    <div>
      <span class="db-label">DATABASE</span>
      <span class="db-value">KOWORI_GAME_ARCHIVE</span>
    </div>
    <div>
      <span class="db-label">RECORDS</span>
      <span class="db-value">{total}</span>
    </div>
    <div>
      <span class="db-label">VAULT</span>
      <span class="db-value">{backlogTotal}/{total}</span>
    </div>
    <div class="sort-controls">
      <button class="sort-btn" data-view-mode="files" data-active="true">FILES</button>
      <button class="sort-btn" data-view-mode="asc">ASC</button>
      <button class="sort-btn" data-view-mode="desc">DESC</button>
    </div>
  </div>

  <dl class="status-guide terminal-panel">
    <div data-status-filter-cell="active">
      <dt>
        <button class="status-filter status-text active" data-status-filter="active" type="button">ACTIVE</button>
      </dt>
      <dd>&gt; playing now</dd>
    </div>
    <div data-status-filter-cell="backlog">
      <dt>
        <button class="status-filter status-text backlog" data-status-filter="backlog" type="button">VAULT</button>
      </dt>
      <dd>&gt; backlog / parked</dd>
    </div>
    <div data-status-filter-cell="cleared">
      <dt>
        <button class="status-filter status-text cleared" data-status-filter="cleared" type="button">CLEAR</button>
      </dt>
      <dd>&gt; finished enough</dd>
    </div>
  </dl>

  <div class="platform-grid">
    {library.filter(g => g.games.length > 0).map(group => (
      <div class="platform-box terminal-panel" data-platform-box>
        <div class="terminal-titlebar">
          <span>FILE: {group.platform}</span>
          <span class="terminal-meta">{group.games.length} RECORDS</span>
        </div>
        <ul>
          {group.games.map(g => {
            const status = gameStatus(g);
            return (
              <li data-status={status}>
                <span class="bullet">&gt;</span>
                <span class="game-title">{g.title}</span>
                {g.score !== undefined && (
                  <span
                    class:list={["score-badge", { "hall-of-fame": g.rank === 0 }]}
                    style={`color: ${scoreColor(g.score)}; border-color: ${scoreColor(g.score)}66;`}
                  >
                    {g.rank === 0 && <span class="score-star">★</span>}
                    {g.score}<span class="score-max">/10</span>
                  </span>
                )}
                <span class:list={["status-badge", status]}>
                  {statusLabels[status]}
                </span>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>

  <div class="list-view terminal-panel" hidden>
    <div class="terminal-titlebar">
      <span>INDEX: TITLE_SCAN</span>
      <span class="terminal-meta">{allGames.length} RECORDS</span>
    </div>
    <div class="list-table">
      <div class="list-row list-head">
        <span>TITLE</span>
        <span>PLATFORM</span>
        <span>STATUS</span>
        <span>SCORE</span>
      </div>
      {allGames.map(g => {
        const status = gameStatus(g);
        return (
          <div class="list-row" data-list-row data-status={status} data-title={g.title}>
            <span class="list-title">
              <span class="bullet">&gt;</span>
              {g.title}
            </span>
            <span class="list-platform">{g.platform}</span>
            <span>
              <span class:list={["status-badge", status]}>{statusLabels[status]}</span>
            </span>
            <span>
              {g.score !== undefined ? (
                <span
                  class:list={["score-badge", { "hall-of-fame": g.rank === 0 }]}
                  style={`color: ${scoreColor(g.score)}; border-color: ${scoreColor(g.score)}66;`}
                >
                  {g.rank === 0 && <span class="score-star">★</span>}
                  {g.score}<span class="score-max">/10</span>
                </span>
              ) : (
                <span class="score-empty">--</span>
              )}
            </span>
          </div>
        );
      })}
    </div>
  </div>

  {library.some(g => g.games.length === 0) && (
    <div class="tbd-grid" data-files-extra>
      {library.filter(g => g.games.length === 0).map(group => (
        <div class="platform-box empty terminal-panel">
          <div class="terminal-titlebar">
            <span>FILE: {group.platform}</span>
            <span class="terminal-meta">NO DATA</span>
          </div>
          <div class="tbd">// TBD</div>
        </div>
      ))}
    </div>
  )}

  <div class="lostfound-section">
    <h2 class="lostfound-title">🗑️ LOST &amp; FOUND</h2>
    <div class="platform-box lostfound-box terminal-panel">
      <ul>
        <li><span class="bullet">&gt;</span>エグゾイドZ</li>
      </ul>
    </div>
  </div>

  <section class="library-rules terminal-panel" aria-labelledby="library-rules-title">
    <div class="terminal-titlebar">
      <h2 id="library-rules-title">LIBRARY RULES</h2>
    </div>
    <ul>
      <li>現在手元にあるゲームのみ記載する。廃棄・売却済みのゲームやゲーム機は記載しない。</li>
      <li>買い戻したゲームは、買い戻す前にクリアしていればCLEARとして扱う。</li>
      <li>古すぎて記憶が曖昧なゲームは、暫定的にVAULTとして扱う。</li>
    </ul>
  </section>
</Layout>

<style>
  .collection-type {
    font-size: var(--font-sm);
    color: var(--color-accent);
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.1em;
  }

  .platform-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .platform-grid[hidden],
  .list-view[hidden],
  .list-row[hidden],
  [data-files-extra][hidden],
  [data-platform-box][hidden] {
    display: none;
  }

  .db-header {
    display: grid;
    grid-template-columns: 1.5fr 0.7fr 0.8fr auto;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .db-header > div {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .db-label {
    font-family: var(--font-pixel);
    font-size: 0.38rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }

  .db-value {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    text-shadow: 0 0 6px var(--color-primary);
  }

  .status-guide {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
  }

  .status-guide div {
    padding: var(--space-2) var(--space-3);
    border-left: 1px solid var(--color-border);
    cursor: pointer;
  }

  .status-guide div:has(.status-filter[data-active="true"]) {
    background: rgba(0, 255, 102, 0.08);
    box-shadow: inset 0 0 0 1px rgba(0, 255, 102, 0.22);
  }

  .status-guide div:has(.status-filter.backlog[data-active="true"]) {
    background: rgba(150, 160, 150, 0.1);
    box-shadow: inset 0 0 0 1px rgba(150, 160, 150, 0.24);
  }

  .status-guide div:has(.status-filter.cleared[data-active="true"]) {
    background: rgba(31, 127, 76, 0.14);
    box-shadow: inset 0 0 0 1px rgba(31, 127, 76, 0.28);
  }

  .status-guide div:first-child {
    border-left: none;
  }

  .status-guide dt {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.08em;
  }

  .status-filter {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    font: inherit;
    letter-spacing: inherit;
    cursor: pointer;
  }

  .status-filter:hover,
  .status-filter[data-active="true"] {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .status-filter[data-active="true"]::before {
    content: "[";
  }

  .status-filter[data-active="true"]::after {
    content: "]";
  }

  .status-guide dd {
    margin: 4px 0 0;
    color: var(--color-muted);
    font-size: var(--font-sx);
  }

  @media (max-width: 600px) {
    .db-header {
      grid-template-columns: 1fr;
    }

    .status-guide {
      grid-template-columns: 1fr;
    }

    .status-guide div {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }

    .status-guide div:first-child {
      border-top: none;
    }
  }

  .platform-box {
    padding: 0;
  }

  .tbd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  @media (max-width: 600px) {
    .tbd-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .lostfound-section {
    margin-top: var(--space-6);
    border-top: 2px dashed var(--color-border);
    padding-top: var(--space-4);
  }

  .lostfound-title {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }

  .lostfound-box {
    border-style: dashed;
    opacity: 0.6;
  }

  .library-rules {
    margin-top: var(--space-5);
    padding: 0;
  }

  .library-rules h2 {
    margin: 0;
    font: inherit;
  }

  .library-rules ul {
    margin: 0;
    padding: var(--space-3) var(--space-3) var(--space-3) calc(var(--space-3) + 1.2rem);
    font-size: var(--font-sm);
  }

  .library-rules li + li {
    margin-top: var(--space-2);
  }

  .platform-box.empty {
    border-style: dashed;
    opacity: 0.4;
  }

  .tbd {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    padding: var(--space-3);
  }

  .platform-box ul {
    list-style: none;
    margin: 0;
    padding: var(--space-3);
    font-size: var(--font-sm);
    columns: 3;
    column-gap: var(--space-5);
  }

  @media (max-width: 600px) {
    .platform-box ul { columns: 2; }
  }

  .platform-box li {
    margin-bottom: var(--space-1);
    color: var(--color-text);
    break-inside: avoid;
  }

  .list-view {
    padding: 0;
  }

  .list-table {
    padding: var(--space-3);
    font-size: var(--font-sm);
  }

  .list-row {
    display: grid;
    grid-template-columns: minmax(180px, 1.4fr) minmax(100px, 0.8fr) minmax(78px, auto) minmax(56px, auto);
    gap: var(--space-3);
    align-items: center;
    padding: 3px 0;
    border-bottom: 1px dashed rgba(0, 255, 102, 0.12);
  }

  .list-row:last-child {
    border-bottom: 0;
  }

  .list-head {
    font-family: var(--font-pixel);
    font-size: 0.38rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-1);
  }

  .list-title,
  .list-platform {
    min-width: 0;
  }

  .score-empty {
    color: var(--color-muted);
    font-family: var(--font-pixel);
    font-size: 0.4rem;
  }

  @media (max-width: 700px) {
    .list-row {
      grid-template-columns: 1fr;
      gap: 2px;
      padding: var(--space-2) 0;
    }

    .list-head {
      display: none;
    }

    .list-platform {
      color: var(--color-muted);
      font-size: var(--font-xs);
    }
  }

  .bullet {
    color: var(--color-primary);
    margin-right: 4px;
    font-family: var(--font-pixel);
    font-size: 0.48rem;
  }

  .game-title {
    margin-right: 6px;
  }

  .score-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
    border: 1px solid;
    padding: 1px 4px;
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    line-height: 1.4;
    white-space: nowrap;
    text-shadow: 0 0 6px currentColor;
    vertical-align: 1px;
  }

  .score-badge.hall-of-fame {
    border-color: #ffd70099 !important;
  }

  .score-star {
    color: #ffd700;
    margin-right: 2px;
  }

  .score-max {
    color: var(--color-muted);
    font-size: 0.34rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
    padding: 1px 5px;
    font-family: var(--font-pixel);
    font-size: 0.38rem;
    line-height: 1.4;
    white-space: nowrap;
    vertical-align: 1px;
  }

  .status-badge.active {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }

  .status-text.active {
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }

  .status-badge.backlog {
    border-color: var(--color-muted);
    color: var(--color-muted);
  }

  .status-text.backlog {
    color: var(--color-muted);
  }

  .status-badge.cleared {
    border-color: #1f7f4c;
    color: #1f7f4c;
  }

  .status-text.cleared {
    color: #1f7f4c;
  }

  .sort-controls {
    display: flex;
    gap: var(--space-2);
    justify-content: flex-end;
  }

  .sort-btn {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.08em;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    padding: 2px 8px;
    cursor: pointer;
  }

  .sort-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .sort-btn[data-active="true"] {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }
</style>

<script>
  type ViewMode = "files" | "asc" | "desc";
  type StatusFilter = "active" | "backlog" | "cleared";

  const platformGrid = document.querySelector<HTMLElement>(".platform-grid");
  const listView = document.querySelector<HTMLElement>(".list-view");
  const listTable = document.querySelector<HTMLElement>(".list-table");
  const listRows = [...document.querySelectorAll<HTMLElement>("[data-list-row]")];
  let activeView: ViewMode = "files";
  let activeFilter: StatusFilter | null = null;

  function applyFilter() {
    document.querySelectorAll<HTMLButtonElement>(".status-filter").forEach(btn => {
      btn.dataset.active = btn.dataset.statusFilter === activeFilter ? "true" : "false";
    });

    document.querySelectorAll<HTMLElement>("[data-platform-box]").forEach(box => {
      const items = [...box.querySelectorAll<HTMLLIElement>("li[data-status]")];
      items.forEach(li => {
        const visible = activeFilter === null || li.dataset.status === activeFilter;
        li.hidden = !visible;
      });
      box.hidden = items.length > 0 && items.every(li => li.hidden);
    });

    listRows.forEach(row => {
      const visible = activeFilter === null || row.dataset.status === activeFilter;
      row.hidden = !visible;
    });
  }

  function applyView(mode: ViewMode) {
    activeView = mode;

    document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
      btn.dataset.active = btn.dataset.viewMode === activeView ? "true" : "false";
    });

    if (platformGrid) platformGrid.hidden = activeView !== "files";
    document.querySelectorAll<HTMLElement>("[data-files-extra]").forEach(el => {
      el.hidden = activeView !== "files";
    });
    if (listView) listView.hidden = activeView === "files";

    if (activeView !== "files" && listTable) {
      const sortedRows = [...listRows].sort((a, b) => {
        const ta = a.dataset.title ?? "";
        const tb = b.dataset.title ?? "";
        return activeView === "asc"
          ? ta.localeCompare(tb, "ja")
          : tb.localeCompare(ta, "ja");
      });
      sortedRows.forEach(row => listTable.appendChild(row));
    }

    applyFilter();
  }

  applyView("files");

  document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      applyView(btn.dataset.viewMode as ViewMode);
    });
  });

  document.querySelectorAll<HTMLElement>("[data-status-filter-cell]").forEach(cell => {
    cell.addEventListener("click", () => {
      const nextFilter = cell.dataset.statusFilterCell as StatusFilter;
      activeFilter = activeFilter === nextFilter ? null : nextFilter;
      applyFilter();
    });
  });
</script>
