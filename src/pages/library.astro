const total = library.reduce((sum, p) => sum + p.games.length, 0);
---

<Layout title="library" description="所持ゲーム一覧">
  <h1>LIBRARY <span class="collection-type">// Physical &amp; Digital Collection</span></h1>
  <div class="header-row">
    <p class="sub">// {total} titles in collection</p>
    <div class="sort-controls">
      <button class="sort-btn" data-sort="asc" data-active="true">ASC</button>
      <button class="sort-btn" data-sort="desc">DESC</button>
    </div>
  </div>

  <div class="platform-grid">
    {library.filter(g => g.games.length > 0).map(group => (
      <div class="platform-box">
        <div class="platform-label">{group.platform}</div>
        <div class="count-badge">{group.games.length} titles</div>
        <ul>
          {group.games.map(g => {
            const slug = reviewSlug(g);
            return (
              <li>
                <span class="bullet">-</span>
                {slug
                  ? <a href={`/reviews#${slug}`} class="reviewed">{g}</a>
                  : g
                }
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>

  {library.some(g => g.games.length === 0) && (
    <div class="tbd-grid">
      {library.filter(g => g.games.length === 0).map(group => (
        <div class="platform-box empty">
          <div class="platform-label">{group.platform}</div>
          <div class="tbd">// TBD</div>
        </div>
      ))}
    </div>
  )}

  <div class="lostfound-section">
    <h2 class="lostfound-title">🗑️ LOST &amp; FOUND</h2>
    <div class="platform-box lostfound-box">
      <ul>
        <li><span class="bullet">-</span>エグゾイドZ</li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  .collection-type {
    font-size: var(--font-sm);
    color: var(--color-accent);
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.1em;
  }

  .sub {
    font-size: var(--font-sm);
    color: var(--color-muted);
  }

  .platform-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .platform-box {
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-3);
  }

  .tbd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  @media (max-width: 600px) {
    .tbd-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .lostfound-section {
    margin-top: var(--space-6);
    border-top: 2px dashed var(--color-border);
    padding-top: var(--space-4);
  }

  .lostfound-title {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }

  .lostfound-box {
    border-style: dashed;
    opacity: 0.6;
  }

  .platform-box.empty {
    border-style: dashed;
    opacity: 0.4;
  }

  .tbd {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
  }

  .platform-label {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-1);
    padding-bottom: var(--space-2);
    border-bottom: 1px dashed var(--color-border);
  }

  .count-badge {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .platform-box ul {
    list-style: none;
    margin: 0;
    font-size: var(--font-sm);
    columns: 3;
    column-gap: var(--space-5);
  }

  @media (max-width: 600px) {
    .platform-box ul { columns: 2; }
  }

  .platform-box li {
    margin-bottom: var(--space-1);
    color: var(--color-text);
  }

  .bullet {
    color: var(--color-muted);
    margin-right: 4px;
  }

  a.reviewed {
    color: var(--color-primary);
    text-decoration: none;
  }

  a.reviewed:hover {
    text-decoration: underline;
  }

  .header-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .sub {
    margin: 0;
  }

  .sort-controls {
    display: flex;
    gap: var(--space-2);
    margin-left: auto;
  }

  .sort-btn {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.08em;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    padding: 2px 8px;
    cursor: pointer;
  }

  .sort-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .sort-btn[data-active="true"] {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }
</style>

<script>
  type SortOrder = "default" | "asc" | "desc";

  // 各ulのli要素を元の順序で記憶
  const lists = document.querySelectorAll<HTMLUListElement>(".platform-box ul");
  const originals = new Map<HTMLUListElement, HTMLLIElement[]>();
  lists.forEach(ul => {
    originals.set(ul, [...ul.querySelectorAll<HTMLLIElement>("li")]);
  });

  function applySort(order: SortOrder) {
    lists.forEach(ul => {
      const items = order === "default"
        ? [...(originals.get(ul) ?? [])]
        : [...ul.querySelectorAll<HTMLLIElement>("li")].sort((a, b) => {
            const ta = a.textContent?.trim() ?? "";
            const tb = b.textContent?.trim() ?? "";
            return order === "asc"
              ? ta.localeCompare(tb, "ja")
              : tb.localeCompare(ta, "ja");
          });
      items.forEach(li => ul.appendChild(li));
    });
  }

  applySort("asc");

  document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".sort-btn").forEach(b => b.removeAttribute("data-active"));
      btn.dataset.active = "true";
      applySort(btn.dataset.sort as SortOrder);
    });
  });
</script>
