---
import Layout from "../layouts/Layout.astro";
import Alert from "../components/Alert.astro";
import BlueSkyFeed from "../components/BlueSkyFeed.astro";
import YouTubeFeed from "../components/YouTubeFeed.astro";
import TopReviews from "../components/TopReviews.astro";

const twitter = { text: "Twitter", url: "https://twitter.com/kowori_fallout", handle: "@kowori_fallout", color: "#1d9bf0", icon: "𝕏" };
const bluesky  = { text: "BlueSky", url: "https://bsky.app/profile/tadakori.bsky.social", handle: "@tadakori.bsky.social", color: "#0085ff", icon: "🦋" };
const youtube  = { text: "YouTube", url: "https://www.youtube.com/channel/UC2-6vCCrGTqCDE6tTQ9TtKw", handle: "ただこりさんち", color: "#ff0000", icon: "▶" };
---

<Layout title="top">
  <a href="https://twitter.com/kowori_fallout" class="screen">
    <div class="avatar-wrap">
      <img src="/robot_a.png" alt="" width="64" height="64" class="avatar" />
    </div>
    <p class="handle">&gt; callme tadakori-san.</p>
    <p class="tagline">// lazy play</p>
    <p class="oracle" id="oracle"></p>
  </a>

  <hr />

  <Alert />

  <nav class="page-nav">
    <a href="/games" class="nav-card">
      <span class="label">[ NOW PLAYING ]</span>
      <span class="desc">プレイ中のゲーム</span>
    </a>
    <a href="/machines" class="nav-card">
      <span class="label">[ MACHINES ]</span>
      <span class="desc">所持ゲーム機</span>
    </a>
    <a href="/reviews" class="nav-card">
      <span class="label">[ REVIEWS ]</span>
      <span class="desc">ただこりさんによる独断と偏見</span>
    </a>
    <a href="/notes" class="nav-card">
      <span class="label">[ NOTES ]</span>
      <span class="desc">メモ</span>
    </a>
    <a href="/library" class="nav-card">
      <span class="label">[ LIBRARY ]</span>
      <span class="desc">所持ゲーム一覧</span>
    </a>
  </nav>

  <hr />

  <TopReviews />

  <hr />

  <section id="contact">
    <h2 class="section-title">[ CONTACT ]</h2>

    <div class="social-section">
      <a href={twitter.url} target="_blank" rel="noopener" class="social-card" style={`--card-color: ${twitter.color}`}>
        <span class="social-icon">{twitter.icon}</span>
        <span class="social-info">
          <span class="social-name">{twitter.text}</span>
          <span class="social-handle">{twitter.handle}</span>
        </span>
        <span class="social-arrow">→</span>
      </a>

      <a href={bluesky.url} target="_blank" rel="noopener" class="social-card" style={`--card-color: ${bluesky.color}`}>
        <span class="social-icon">{bluesky.icon}</span>
        <span class="social-info">
          <span class="social-name">{bluesky.text}</span>
          <span class="social-handle">{bluesky.handle}</span>
        </span>
        <span class="social-arrow">→</span>
      </a>
      <BlueSkyFeed />

      <a href={youtube.url} target="_blank" rel="noopener" class="social-card" style={`--card-color: ${youtube.color}`}>
        <span class="social-icon">{youtube.icon}</span>
        <span class="social-info">
          <span class="social-name">{youtube.text}</span>
          <span class="social-handle">{youtube.handle}</span>
        </span>
        <span class="social-arrow">→</span>
      </a>
      <YouTubeFeed />
    </div>
  </section>
</Layout>

<script>
const phrases = [
  // プレイスタイル
  "MMOを複数渡り歩いているが、全部休止。気が向いたら触る、飽きたら離れる。それだけのこと。",
  "やるときはやり込む。FF14は7.0まで、DQ10は占い師120まで。やりきったら離れる派。",
  // 好みの傾向
  "ストーリーと世界観が好きな、気まぐれ渡り鳥ゲーマー。Fallout だけは別格。",
  "RPG・シミュレーション中心。90年代のコアなタイトルも守備範囲。レトロへの素養あり。",
  "Twitter IDが kowori_fallout。それがすべてを物語っている。",
  // 人となり
  "lazy play とは言うが、発信はしている。ゆるく共有したい気持ちはある。",
  "ピクセルフォントとCRT風UIを選ぶ。懐かし系の美意識。",
];

const el = document.getElementById("oracle");
if (el) {
  const picked = phrases[Math.floor(Math.random() * phrases.length)];
  el.innerHTML = `賢者クロウド曰く　<br>　　🧙‍♂️「${picked}」`;
}
</script>

<style>
  .screen {
    display: block;
    background: var(--color-surface);
    border: var(--pixel-border);
    box-shadow: var(--pixel-shadow);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    text-decoration: none;
    cursor: pointer;
  }

  .screen:hover {
    text-decoration: none;
    border-color: var(--color-primary);
  }

  .avatar-wrap {
    margin-bottom: var(--space-3);
  }

  .avatar {
    image-rendering: pixelated;
  }

  .handle {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-primary);
    text-shadow: 0 0 8px var(--color-primary);
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .tagline {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin: 0;
    max-width: none;
  }

  .oracle {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin-top: var(--space-3);
    max-width: none;
    opacity: 0.7;
    font-style: italic;
  }

  .page-nav {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.1s, box-shadow 0.1s;
  }

  .nav-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--pixel-shadow);
    text-decoration: none;
  }

  .nav-card .label {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
  }

  .nav-card .desc {
    font-size: var(--font-sm);
    color: var(--color-muted);
  }

  /* CONTACT セクション */
  .section-title {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .social-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0 var(--space-5);
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-left: 4px solid var(--card-color);
    text-decoration: none;
    transition: border-color 0.1s, background 0.1s;
  }

  .social-card:hover {
    background: #1a1a3a;
    border-color: var(--card-color);
    text-decoration: none;
  }

  .social-icon {
    font-size: 1.2rem;
    width: 2rem;
    text-align: center;
    flex-shrink: 0;
    filter: grayscale(0.3);
  }

  .social-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .social-name {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-text);
    letter-spacing: 0.05em;
  }

  .social-handle {
    font-size: var(--font-sm);
    color: var(--color-muted);
  }

  .social-arrow {
    color: var(--color-muted);
    font-size: var(--font-sm);
    flex-shrink: 0;
  }

  .social-card:hover .social-arrow {
    color: var(--color-primary);
  }
</style>
