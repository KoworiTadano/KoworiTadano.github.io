---
import Layout from "../layouts/Layout.astro";
import Alert from "../components/Alert.astro";
import { getCollection } from "astro:content";
import { allGames, gameStatus, statusLabels } from "../data/library";

const twitter = { text: "Twitter", url: "https://twitter.com/kowori_fallout", handle: "@kowori_fallout", color: "#1d9bf0", icon: "𝕏" };
const bluesky  = { text: "BlueSky", url: "https://bsky.app/profile/tadakori.bsky.social", handle: "@tadakori.bsky.social", color: "#0085ff", icon: "🦋" };
const youtube  = { text: "YouTube", url: "https://www.youtube.com/channel/UC2-6vCCrGTqCDE6tTQ9TtKw", handle: "ただこりさんち", color: "#ff0000", icon: "▶" };

const activeGames = allGames.filter(game => gameStatus(game) === "active");
const backlogTotal = allGames.filter(game => gameStatus(game) === "backlog").length;
const totalGames = allGames.length;
const latestPost = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())[0];
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(date);
---

<Layout title="top">
  <a href="https://twitter.com/kowori_fallout" class="screen">
    <div class="avatar-wrap">
      <img src="/robot_a.png" alt="" width="64" height="64" class="avatar" />
    </div>
    <p class="handle">&gt; callme tadakori-san.</p>
    <p class="tagline">// lazy play</p>
    <p class="oracle" id="oracle"></p>
  </a>

  <hr />

  <Alert />

  {latestPost && (
    <a href={`/blog/${latestPost.slug}/`} class="latest-post terminal-panel">
      <span class="latest-label">LATEST BLOG ENTRY</span>
      <span class="latest-title">{latestPost.data.title}</span>
      <time datetime={latestPost.data.published.toISOString()}>
        {formatDate(latestPost.data.published)}
      </time>
    </a>
  )}

  <section class="status-panel">
    <div class="terminal-panel status-box">
      <div class="terminal-titlebar">
        <span>STATUS: ACTIVE PLAY</span>
        <span class="terminal-meta">LIVE</span>
      </div>
      {activeGames.length > 0 ? (
        <ul class="active-list">
          {activeGames.map(game => (
            <li>
              <span class="active-marker">▶</span>
              <span>{game.title}</span>
              <span class="active-platform">{game.platform}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-status">&gt; no active games_</p>
      )}
    </div>
    <a href="/library" class="terminal-panel vault-meter">
      <span class="meter-label">{statusLabels.backlog}</span>
      <span class="meter-fraction">
        <span>{backlogTotal}</span>
        <span class="slash">/</span>
        <span>{totalGames}</span>
      </span>
    </a>
  </section>

  <nav class="page-nav">
    <a href="/machines" class="nav-card terminal-panel">
      <span class="label">[ MACHINES ]</span>
      <span class="desc">所持ゲーム機</span>
    </a>
    <a href="/library" class="nav-card terminal-panel">
      <span class="label">[ LIBRARY ]</span>
      <span class="desc">所持ゲーム一覧と点数</span>
    </a>
  </nav>

  <section class="toybox-section">
    <h2 class="section-title">[ TOYBOX ]</h2>
    <a href="/rf4-seed-level/" class="nav-card terminal-panel">
      <span class="label">[ RF4 SEED LEVEL ]</span>
      <span class="desc">ルーンファクトリー4<br />種レベル管理ツール</span>
    </a>
  </section>

  <hr />

  <section id="contact">
    <h2 class="section-title">[ CONTACT ]</h2>

    <div class="social-section">
      <a href={twitter.url} target="_blank" rel="noopener" class="social-card terminal-panel" style={`--card-color: ${twitter.color}`}>
        <span class="social-icon">{twitter.icon}</span>
        <span class="social-info">
          <span class="social-name">{twitter.text}</span>
          <span class="social-handle">{twitter.handle}</span>
        </span>
        <span class="social-arrow">→</span>
      </a>

      <a href={bluesky.url} target="_blank" rel="noopener" class="social-card terminal-panel" style={`--card-color: ${bluesky.color}`}>
        <span class="social-icon">{bluesky.icon}</span>
        <span class="social-info">
          <span class="social-name">{bluesky.text}</span>
          <span class="social-handle">{bluesky.handle}</span>
        </span>
        <span class="social-arrow">→</span>
      </a>

      <a href={youtube.url} target="_blank" rel="noopener" class="social-card terminal-panel" style={`--card-color: ${youtube.color}`}>
        <span class="social-icon">{youtube.icon}</span>
        <span class="social-info">
          <span class="social-name">{youtube.text}</span>
          <span class="social-handle">{youtube.handle}</span>
        </span>
        <span class="social-arrow">→</span>
      </a>
    </div>
  </section>
</Layout>

<script>
const phrases = [
  // プレイスタイル
  { source: "賢者クロウド曰く", text: "MMOを複数渡り歩いているが、全部休止。気が向いたら触る、飽きたら離れる。それだけのこと。" },
  { source: "賢者クロウド曰く", text: "やるときはやり込む。FF14は7.0まで、DQ10は占い師120まで。やりきったら離れる派。" },
  // 好みの傾向
  { source: "賢者クロウド曰く", text: "ストーリーと世界観が好きな、気まぐれ渡り鳥ゲーマー。Fallout だけは別格。" },
  { source: "賢者クロウド曰く", text: "RPG・シミュレーション中心。90年代のコアなタイトルも守備範囲。レトロへの素養あり。" },
  { source: "賢者クロウド曰く", text: "Twitter IDが kowori_fallout。それがすべてを物語っている。" },
  // 人となり
  { source: "賢者クロウド曰く", text: "lazy play とは言うが、発信はしている。ゆるく共有したい気持ちはある。" },
  { source: "賢者クロウド曰く", text: "ピクセルフォントとCRT風UIを選ぶ。懐かし系の美意識。" },
  // Codex
  { source: "電子写本より抜粋", text: "遊ぶゲームを棚に並べるだけでなく、状態を付けて眺めたい人。攻略より先に、自分の遊び方を整理するのが好き。" },
  { source: "電子写本より抜粋", text: "Fallout、女神転生、古いPCゲームに反応する。明るい冒険譚より、少し壊れた世界や変な思想のあるRPGに惹かれる。" },
  { source: "電子写本より抜粋", text: "積みゲーを罪とは呼ばず、保管庫に眠る資産として扱うタイプ。いつか戻る余地をちゃんと残している。" },
  { source: "電子写本より抜粋", text: "コメントを書くより点数を置くほうが性に合う。語りすぎないが、10点の棚にはかなり強い信仰がある。" },
  { source: "電子写本より抜粋", text: "サイト全体に、古い端末と個人BBSの気配を残している。派手に見せるより、自分の基地として落ち着くことを優先する。" },
];

const el = document.getElementById("oracle");
if (el) {
  const picked = phrases[Math.floor(Math.random() * phrases.length)];
  el.innerHTML = `${picked.source}<br>　　「${picked.text}」`;
}
</script>

<style>
  .screen {
    display: block;
    background: var(--color-surface);
    border: var(--pixel-border);
    box-shadow: var(--pixel-shadow);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    text-decoration: none;
    cursor: pointer;
  }

  .screen:hover {
    text-decoration: none;
    border-color: var(--color-primary);
  }

  .avatar-wrap {
    margin-bottom: var(--space-3);
  }

  .avatar {
    image-rendering: pixelated;
  }

  .handle {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-primary);
    text-shadow: 0 0 8px var(--color-primary);
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .tagline {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin: 0;
    max-width: none;
  }

  .oracle {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin-top: var(--space-3);
    max-width: none;
    opacity: 0.7;
    font-style: italic;
  }

  .latest-post {
    align-items: center;
    display: grid;
    gap: var(--space-2) var(--space-3);
    grid-template-columns: 1fr auto;
    margin-bottom: var(--space-5);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
  }

  .latest-post:hover {
    border-color: var(--color-primary);
    box-shadow: var(--panel-shadow), var(--pixel-shadow);
    text-decoration: none;
  }

  .latest-label {
    color: var(--color-accent);
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    grid-column: 1 / -1;
    letter-spacing: 0.08em;
  }

  .latest-title {
    color: var(--color-primary);
    font-size: var(--font-md);
    font-weight: 700;
  }

  .latest-post time {
    color: var(--color-muted);
    font-family: var(--font-pixel);
    font-size: 0.42rem;
  }

  .page-nav {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    transition: border-color 0.1s, box-shadow 0.1s;
  }

  .nav-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--panel-shadow), var(--pixel-shadow);
    text-decoration: none;
  }

  .nav-card .label {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
  }

  .nav-card .desc {
    font-size: var(--font-sm);
    color: var(--color-muted);
  }

  .toybox-section {
    margin-bottom: var(--space-5);
  }

  .toybox-section .nav-card {
    max-width: 320px;
  }

  .status-panel {
    display: grid;
    grid-template-columns: 1fr minmax(160px, 220px);
    gap: var(--space-3);
    align-items: stretch;
    margin-bottom: var(--space-5);
  }

  .status-box,
  .vault-meter {
    padding: var(--space-3) var(--space-4);
  }

  .status-box {
    padding: 0;
  }

  .status-box .active-list,
  .status-box .empty-status {
    padding: var(--space-3) var(--space-4);
  }

  .active-list {
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .active-list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin: 0;
    font-size: var(--font-sm);
  }

  .active-marker {
    color: var(--color-primary);
    font-size: 0.6rem;
    text-shadow: 0 0 6px var(--color-primary);
  }

  .active-platform {
    color: var(--color-muted);
    font-size: var(--font-sx);
    margin-left: auto;
  }

  .empty-status {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
  }

  .vault-meter {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-2);
    text-decoration: none;
  }

  .vault-meter:hover {
    border-color: var(--color-primary);
    box-shadow: var(--panel-shadow), var(--pixel-shadow);
    text-decoration: none;
  }

  .meter-label {
    font-family: var(--font-pixel);
    font-size: 0.48rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }

  .meter-fraction {
    display: flex;
    align-items: baseline;
    gap: 4px;
    font-family: var(--font-pixel);
    font-size: 1.5rem;
    color: var(--color-primary);
    text-shadow: 0 0 8px var(--color-primary);
  }

  .slash {
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 600px) {
    .latest-post {
      grid-template-columns: 1fr;
    }

    .status-panel {
      grid-template-columns: 1fr;
    }
  }

  /* CONTACT セクション */
  .section-title {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .social-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0 var(--space-5);
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-left: 4px solid var(--card-color);
    text-decoration: none;
    transition: border-color 0.1s, background 0.1s;
  }

  .social-card:hover {
    background: #1a1a3a;
    border-color: var(--card-color);
    box-shadow: var(--panel-shadow), 3px 3px 0px var(--card-color);
    text-decoration: none;
  }

  .social-icon {
    font-size: 1.2rem;
    width: 2rem;
    text-align: center;
    flex-shrink: 0;
    filter: grayscale(0.3);
  }

  .social-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .social-name {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-text);
    letter-spacing: 0.05em;
  }

  .social-handle {
    font-size: var(--font-sm);
    color: var(--color-muted);
  }

  .social-arrow {
    color: var(--color-muted);
    font-size: var(--font-sm);
    flex-shrink: 0;
  }

  .social-card:hover .social-arrow {
    color: var(--color-primary);
  }
</style>
