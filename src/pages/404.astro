---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404">
  <div class="wrap">
    <p class="code">404</p>
    <p class="msg">// PAGE NOT FOUND</p>
    <p class="detail">そのページは存在しない。あるいは、迷子になった。</p>
    <p class="redirect">
      <span id="count">10</span>秒後にトップへ戻ります...
    </p>
    <a href="/" class="back">[ TOP へ戻る ]</a>
  </div>
</Layout>

<script>
  let count = 10;
  const el = document.getElementById("count");
  const timer = setInterval(() => {
    count--;
    if (el) el.textContent = String(count);
    if (count <= 0) {
      clearInterval(timer);
      location.href = "/";
    }
  }, 1000);
</script>

<style>
  .wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    text-align: center;
    gap: var(--space-3);
  }

  .code {
    font-family: var(--font-pixel);
    font-size: 4rem;
    color: var(--color-accent);
    text-shadow: 0 0 20px var(--color-accent);
    margin: 0;
    line-height: 1;
    animation: flicker 4s infinite;
  }

  @keyframes flicker {
    0%, 92%, 100% { opacity: 1; }
    93% { opacity: 0.2; }
    95% { opacity: 0.8; }
    97% { opacity: 0.3; }
  }

  .msg {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .detail {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin: 0;
    max-width: none;
  }

  .redirect {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin: 0;
    max-width: none;
  }

  #count {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    color: var(--color-primary);
  }

  .back {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    padding: var(--space-2) var(--space-4);
    border: 2px solid var(--color-border);
    margin-top: var(--space-3);
  }

  .back:hover {
    border-color: var(--color-primary);
    box-shadow: var(--pixel-shadow);
    text-decoration: none;
  }
</style>
