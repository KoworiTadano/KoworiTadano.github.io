---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const reviews = (await getCollection("reviews")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const scoreColor = (score: number) => {
  if (score >= 9) return "#00ffcc";
  if (score >= 7) return "#ffe566";
  if (score >= 5) return "#ff9500";
  return "#ff2d78";
};
---

<Layout title="reviews" description="ただこりさんによるゲームレビュー">
  <h1>REVIEWS</h1>
  <div class="header-row">
    <p class="sub">// ただこりさんによる独断と偏見</p>
    <div class="sort-controls">
      <span class="sort-label">SORT:</span>
      <button class="sort-btn" data-sort="date-desc" data-active="true">新しい順</button>
      <button class="sort-btn" data-sort="date-asc">古い順</button>
      <button class="sort-btn" data-sort="title-asc">タイトル</button>
    </div>
  </div>

  <div class="review-list">
    {reviews.map(async review => {
      const { Content } = await review.render();
      return (
        <div class="review-card" id={review.slug}
          data-title={review.data.title}
          data-date={review.data.date.valueOf()}>
          <div class="card-header">
            <span class="game-title">{review.data.title}</span>
          </div>
          <div class="card-body">
            <div class="reviewer">
              <img src="/robot_a.png" alt="" width="48" height="48" class="reviewer-icon" />
              <span class="reviewer-name">ただこりさん</span>
              <div class="score-wrap">
                <span class="score-label">SCORE</span>
                <span class="score" style={`color: ${scoreColor(review.data.score)}; text-shadow: 0 0 10px ${scoreColor(review.data.score)}`}>
                  {review.data.score}
                </span>
                <span class="score-max">/10</span>
              </div>
            </div>
            <div class="review-content">
              <div class="review-text">
                <Content />
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</Layout>

<style>
  .sub {
    font-size: var(--font-sm);
    color: var(--color-muted);
    margin: 0;
  }

  .header-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .sort-controls {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-left: auto;
  }

  .sort-label {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }

  .sort-btn {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    letter-spacing: 0.05em;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    padding: 2px 8px;
    cursor: pointer;
  }

  .sort-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .sort-btn[data-active="true"] {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-shadow: 0 0 6px var(--color-primary);
  }

  .review-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .review-card {
    border: 2px solid var(--color-border);
    background: var(--color-surface);
  }

  .card-header {
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: #0d0d20;
  }

  .game-title {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
  }

  .card-body {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    align-items: flex-start;
  }

  .reviewer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    width: 120px;
  }

  .reviewer-icon {
    image-rendering: pixelated;
    border: 2px solid var(--color-border);
    width: 108px;
    height: 108px;
  }

  .reviewer-name {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--color-muted);
    text-align: center;
    letter-spacing: 0.02em;
    line-height: 1;
    width: 100%;
    padding: var(--space-1) 0;
    border: 2px solid var(--color-muted);
    box-shadow: 2px 2px 0px var(--color-muted);
  }

  .review-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .review-text {
    font-size: var(--font-sm);
    color: var(--color-text);
    line-height: 1.8;
  }

  .review-text :global(p) {
    margin: 0;
    max-width: none;
  }

  .score-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    border-top: 1px dashed var(--color-border);
    padding-top: var(--space-2);
    width: 100%;
  }

  .score-label {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    margin-right: var(--space-1);
  }

  .score {
    font-family: var(--font-pixel);
    font-size: 1.8rem;
    line-height: 1;
  }

  .score-max {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-muted);
  }
</style>

<script>
  type SortKey = "date-desc" | "date-asc" | "title-asc";

  const list = document.querySelector<HTMLElement>(".review-list")!;

  function applySort(key: SortKey) {
    const cards = [...list.querySelectorAll<HTMLElement>(".review-card")];
    cards.sort((a, b) => {
      if (key === "title-asc") {
        return (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "", "ja");
      }
      const da = Number(a.dataset.date);
      const db = Number(b.dataset.date);
      return key === "date-asc" ? da - db : db - da;
    });
    cards.forEach(c => list.appendChild(c));
  }

  document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".sort-btn").forEach(b => b.removeAttribute("data-active"));
      btn.dataset.active = "true";
      applySort(btn.dataset.sort as SortKey);
    });
  });
</script>
