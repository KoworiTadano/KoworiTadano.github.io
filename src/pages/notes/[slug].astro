---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

const formatDate = (date: Date) =>
  date.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" });
---

<Layout title={note.data.title}>
  <article>
    <header>
      <p class="back"><a href="/notes">← NOTES</a></p>
      <h1>{note.data.title}</h1>
      <div class="meta">
        <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
        {note.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  article {
    max-width: 680px;
  }

  .back {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    margin-bottom: var(--space-4);
  }

  header {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  time {
    font-size: var(--font-sm);
    color: var(--color-muted);
  }

  .tag {
    color: var(--color-tag);
    border: 1px solid var(--color-tag);
    padding: 2px 8px;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    letter-spacing: 0.05em;
  }

  .body {
    line-height: 1.9;
    color: var(--color-text);
  }

  .body :global(p) {
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .body :global(h2) {
    margin-top: var(--space-5);
  }
</style>
